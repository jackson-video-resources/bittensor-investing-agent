# Your Bittensor wallet name (set during wallet creation)
WALLET_NAME=my_wallet

# Telegram bot token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID — get from @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# Your cost basis in GBP (what you paid for your TAO)
COST_BASIS_GBP=0

# 10x Dashboard API key (optional — for the live dashboard)
DASHBOARD_API_KEY=
